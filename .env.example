# ── LLM ──────────────────────────────────────────────────
LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_ai_studio_key_here
OPENAI_API_KEY=your_openai_key_here_optional

# ── DATABASES ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/platform_db
REDIS_URL=rediss://default:your_password@your_host.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://your_host.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
CHROMADB_PERSIST_PATH=./chroma_data

# ── SEARCH & DATA APIs ────────────────────────────────────
TAVILY_API_KEY=tvly-your_key_here
NEWS_API_KEY=your_newsapi_key_here
HUNTER_API_KEY=your_hunter_key_here

# ── OBSERVABILITY ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_pt_your_key_here
LANGCHAIN_PROJECT=universal-agentic-platform

# ── APP SETTINGS ──────────────────────────────────────────
DEMO_MODE=false

# ── FRONTEND ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
