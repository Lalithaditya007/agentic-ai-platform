# ── LLM ──────────────────────────────────────────────────
# Use "google" during development. Switch to "openai" only for final demo.
LLM_PROVIDER=google
GOOGLE_API_KEY=your_google_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── DATABASES ─────────────────────────────────────────────
# PostgreSQL — local (already installed, platform_db already created)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/platform_db

# Redis — Upstash cloud
REDIS_URL=rediss://default:your_redis_password@your-redis-url.upstash.io:6379
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ChromaDB — embedded (no URL needed, stores locally in ./chroma_data)
CHROMADB_PERSIST_PATH=./chroma_data

# ── SEARCH & DATA APIs ────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
NEWS_API_KEY=your_news_api_key_here
HUNTER_API_KEY=your_hunter_api_key_here

# ── OBSERVABILITY ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langchain_api_key_here
LANGCHAIN_PROJECT=universal-agentic-platform

# ── APP SETTINGS ──────────────────────────────────────────
DEMO_MODE=false

# ── FRONTEND ──────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
